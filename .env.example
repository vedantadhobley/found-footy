# Found Footy — environment variables
# Copy to .env and fill in the secrets. .env is gitignored.
#
# Everything else (MongoDB URI, MinIO creds, Temporal host, S3 endpoint,
# DISPLAY, PYTHONPATH, etc.) is set explicitly in docker-compose.{dev,}.yml.
# This file only carries values that are either secrets or per-environment.

# ─── API-Football ──────────────────────────────────────────────────────────
# Sign up at api-football.com → "My Account" → API key
API_FOOTBALL_KEY=your_api_football_key_here

# ─── Twitter login (used by the browser-automation service) ────────────────
# The twitter service logs in with these once and persists cookies to
# /data/twitter_cookies.pkl + ~/.config/found-footy/twitter_cookies.json.
# Cookies typically last weeks; re-auth via the VNC profile when they expire.
TWITTER_USERNAME=your_twitter_handle
TWITTER_PASSWORD=your_twitter_password
TWITTER_EMAIL=your_twitter_email@example.com

# ─── LLM endpoint (Qwen3-VL-8B vision via llama.cpp on joi) ────────────────
# joi runs llama.cpp behind its own Caddy. The hostname `llama-small.joi`
# is split-DNS via Tailscale so containers on the luv-* shared docker
# networks can resolve it. Use the Caddy hostname (no port), not the raw
# Tailscale FQDN + port — keeps this file portable across model swaps.
LLAMA_URL=http://llama-small.joi
# Future: image embeddings for video dedup (see docs/proposals/qwen-embeddings.md)
# LLAMA_EMBED_URL=http://llama-embed.joi

# ─── SSL workaround ────────────────────────────────────────────────────────
# Some upstream video CDNs use certs that python's bundled CA chain
# rejects; we disable verification at the requests layer instead.
PYTHONHTTPSVERIFY=0
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# ─── Frontend host (for SSE refresh callback from worker → vedanta-systems) ─
# Used by monitor_activities.notify_frontend_refresh. Leave as localhost for
# standalone runs; vedanta-systems integration overrides via FRONTEND_API_URL
# in the compose file.
EXTERNAL_HOST=http://localhost
